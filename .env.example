# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tgjobs
POSTGRES_USER=tgjobs
POSTGRES_PASSWORD=changeme

# Backend
SECRET_KEY=changeme-jwt-secret-min-32-chars-long
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
INTERNAL_SECRET=changeme-internal-secret

# Collector → Backend
BACKEND_URL=http://backend:8000

# Telegram MTProto credentials
# Obtain from https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# LLM (OpenRouter) — also editable in the UI settings
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openai/gpt-4o-mini
